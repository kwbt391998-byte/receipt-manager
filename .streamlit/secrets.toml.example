# ════════════════════════════════════════════════════════════
# このファイルは「設定例」です。
# 実際の secrets.toml には本物のAPIキーを書き、
# .gitignore で除外されているため GitHub にはアップされません。
# ════════════════════════════════════════════════════════════

# ── Anthropic API Key (OCR用) ──────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Google Service Account (Google Sheets連携用) ───────────
# Google Cloud Console でサービスアカウントを作成し、
# ダウンロードした JSON の内容をここに貼り付ける
[google_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "abc123..."
private_key = "-----BEGIN RSA PRIVATE KEY-----\nMIIE...(省略)...\n-----END RSA PRIVATE KEY-----\n"
client_email = "receipt-manager@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/receipt-manager%40your-project.iam.gserviceaccount.com"
